# Скопируй в .env и заполни значения
PORT=8080

# Postgres (docker-compose поднимает с этими кредами)
DATABASE_URL=postgres://respect:respect@localhost:5433/respect?sslmode=disable

# Секрет для подписи JWT (минимум 32 символа в проде)
JWT_SECRET=dev-insecure-secret-change-me-please-32b

# Twitch OAuth — создать приложение: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Redirect ДОЛЖЕН быть на origin фронта (Next проксирует /api на бэк): тогда
# сессия-cookie сядет на origin фронта. Этот же URL — в Redirect URLs Twitch-приложения.
TWITCH_REDIRECT_URL=http://localhost:3000/api/auth/twitch/callback

# Куда возвращать пользователя после логина (origin фронта Next.js)
FRONTEND_URL=http://localhost:3000

# Cookie
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Twitch-логины, которым при входе автоматически выдаётся роль organizer (через запятую)
ORGANIZER_TWITCH_LOGINS=denisblim

# Хайлайты: каталог для видео/превью (по умолчанию ./media). Для скачивания твич-клипов
# и превью нужны yt-dlp и ffmpeg в PATH (локально опционально — без них клипы не качаются,
# но загрузка файлов и остальное работает).
MEDIA_DIR=./media
# YTDLP_PATH=yt-dlp
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe
