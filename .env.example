# Скопируй в .env и заполни значения
PORT=8080
# Адрес прослушивания. В проде за nginx укажи 127.0.0.1:8080, чтобы сервис не торчал наружу.
# BIND_ADDR=127.0.0.1:8080

# Postgres (docker-compose поднимает с этими кредами)
DATABASE_URL=postgres://respect:respect@localhost:5433/respect?sslmode=disable

# Секрет подписи JWT. ОБЯЗАТЕЛЕН стойкий секрет (≥32 символов) — без него сервис не стартует.
# Сгенерировать: openssl rand -base64 48
# Для локальной разработки со слабым дефолтным секретом выставь APP_ENV=dev.
JWT_SECRET=
# APP_ENV=dev

# Организатор (superadmin): при старте гарантируется аккаунт с этим логином и ролью superadmin.
# Пароль организатора управляется отсюда — задаётся/обновляется при КАЖДОМ старте. Чтобы менять
# пароль — поправь значение и перезапусти. Оставь пустым, чтобы не трогать существующий аккаунт.
# Остальных организаторов назначает действующий организатор в кабинете («Пользователи»).
SUPERADMIN_LOGIN=Istwood
SUPERADMIN_PASSWORD=

# Origin фронта (Next.js) и настройки cookie сессии.
FRONTEND_URL=http://localhost:3000
COOKIE_DOMAIN=
COOKIE_SECURE=false
# За обратным прокси (nginx) — true: IP клиента берётся из X-Real-IP (его ставит nginx из $remote_addr).
TRUST_PROXY=false

# Хайлайты: каталог для видео/превью (по умолчанию ./media). Для скачивания твич-клипов
# и превью нужны yt-dlp и ffmpeg в PATH (локально опционально — без них клипы не качаются,
# но загрузка файлов и остальное работает).
MEDIA_DIR=./media
# YTDLP_PATH=yt-dlp
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe
